# CONFIGURATION API BACKEND YÉLY (EXEMPLE POUR DÉVELOPPEMENT LOCAL)
NODE_ENV=development
PORT=5000

# Base de données MongoDB locale ou cluster de test
MONGO_URI=mongodb://localhost:27017/yely_dev

# Base Redis locale pour les sockets et le geofencing
REDIS_URL=redis://localhost:6379

# Sécurité (Secrets JWT de 32 caractères minimum)
JWT_SECRET=super_secret_jwt_key_minimum_32_characters_long_for_security
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_minimum_32_characters_long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d
PASSWORD_PEPPER=super_secret_pepper_key_minimum_32_characters_long

# CORS & Sockets (URLs séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000
FRONTEND_URL=http://localhost:8081

# Cloudinary (Gestion des photos de profil, etc.)
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ta_key
CLOUDINARY_API_SECRET=ton_secret

# LocationIQ (Reverse geocoding local)
LOCATION_IQ_TOKEN=pk.4e174e5a5b55092ab9d70c29533077b2

# Firebase Admin SDK (Notification Push Chauffeurs/Clients)
FIREBASE_PROJECT_ID=yely-27b1f
FIREBASE_CLIENT_EMAIL=ton_client_email@yely.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Sentry DSN (Optionnel en local)
# SENTRY_DSN=https://your_sentry_dsn_here
